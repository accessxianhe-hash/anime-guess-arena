# Copy to .env.preview.local before filling real values.
DATABASE_URL="postgresql://user:password@host:5432/anime_guess_preview?schema=public"
NEXTAUTH_SECRET="run: npm run auth:secret"
AUTH_TRUST_HOST="true"

# Optional. If omitted on Vercel Preview, the app can fall back to VERCEL_URL.
NEXTAUTH_URL="https://your-preview-domain.vercel.app"
APP_TIMEZONE="Asia/Shanghai"

ADMIN_SEED_EMAIL="admin@example.com"
ADMIN_SEED_NAME="Site Admin"
ADMIN_SEED_PASSWORD="replace-with-a-strong-password"

STORAGE_PROVIDER="s3"
S3_REGION="auto"
S3_ENDPOINT="https://your-s3-endpoint.example.com"
S3_BUCKET="your-preview-bucket"
S3_ACCESS_KEY_ID="replace-me"
S3_SECRET_ACCESS_KEY="replace-me"
S3_PUBLIC_BASE_URL="https://cdn.example.com"
S3_KEY_PREFIX="preview/"
