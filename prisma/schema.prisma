generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum GameSessionStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum LeaderboardScope {
  DAILY
  ALL_TIME
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Question {
  id                       String          @id @default(cuid())
  canonicalTitle           String
  normalizedCanonicalTitle String          @unique
  imageUrl                 String
  imageStorageKey          String?
  difficulty               Difficulty      @default(MEDIUM)
  tags                     String[]
  active                   Boolean         @default(true)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  aliases                  QuestionAlias[]
  attempts                 AnswerAttempt[]

  @@index([active, difficulty])
}

model QuestionAlias {
  id              String   @id @default(cuid())
  questionId      String
  alias           String
  normalizedAlias String
  createdAt       DateTime @default(now())
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, normalizedAlias])
}

model GameSession {
  id               String             @id @default(cuid())
  status           GameSessionStatus  @default(ACTIVE)
  score            Int                @default(0)
  correctCount     Int                @default(0)
  answeredCount    Int                @default(0)
  startedAt        DateTime           @default(now())
  expiresAt        DateTime
  finishedAt       DateTime?
  submittedAt      DateTime?
  attempts         AnswerAttempt[]
  leaderboardEntry LeaderboardEntry[]

  @@index([status, expiresAt])
}

model AnswerAttempt {
  id                       String      @id @default(cuid())
  sessionId                String
  questionId               String
  submittedAnswer          String
  normalizedSubmittedAnswer String
  isCorrect                Boolean
  scoreAwarded             Int         @default(0)
  answeredAt               DateTime    @default(now())
  session                  GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question                 Question    @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([sessionId, questionId])
  @@index([sessionId, answeredAt])
}

model LeaderboardEntry {
  id             String           @id @default(cuid())
  scope          LeaderboardScope
  dateKey        String?
  nickname       String
  normalizedNickname String
  score          Int
  correctCount   Int
  answeredCount  Int
  accuracy       Float
  durationMs     Int
  sessionId      String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  session        GameSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([scope, sessionId])
  @@unique([scope, dateKey, normalizedNickname])
  @@index([scope, dateKey, score(sort: Desc), durationMs])
}
